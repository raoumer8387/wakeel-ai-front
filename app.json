{
  "expo": {
    "name": "Wakeel AI",
    "slug": "wakeel-ai",
    "scheme": "wakeel-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0a1628"
      },
      "package": "com.wakeelai.legal",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "apiBaseUrl": "https://raoumer866-wakeel-ai-be.hf.space",
      "eas": {
        "projectId": "a86d5999-3f87-44ca-8c44-d3f16b00678d"
      }
    }
  }
}
